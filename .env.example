# Radix Guild Governance — Environment Variables
# Copy to .env and fill in values before running the bot

# ─── Telegram ──────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
TG_BOT_TOKEN=

# Telegram chat ID for governance announcements (group/channel)
GOVERNANCE_CHAT_ID=

# Telegram chat ID for daily bounty summaries (optional)
BOUNTY_NOTIFY_CHAT_ID=

# ─── Radix Network ─────────────────────────────────────────────────────────

# Radix gateway URL
RADIX_GATEWAY_URL=https://gateway.radixscan.io

# Guild badge NFT resource address
BADGE_RESOURCE=resource_rdx1...

# Badge manager component address
BADGE_MANAGER=component_rdx1...

# Admin badge resource address (for admin operations)
ADMIN_BADGE=resource_rdx1...

# ─── Bot API ───────────────────────────────────────────────────────────────

# Port for the REST API (default: 3003)
API_PORT=3003

# Host for the REST API (default: 127.0.0.1)
API_HOST=127.0.0.1

# Public URL of this API service (used for webhook registration)
BOT_API_URL=https://api.guild.radix.community

# API key for admin-protected endpoints (POST /api/cv2/sync, etc.)
ADMIN_API_KEY=

# Comma-separated allowed CORS origins (leave empty for * in dev)
CORS_ORIGINS=https://guild.radix.community

# Portal / dashboard URL (shown in bot messages)
PORTAL_URL=https://guild.radix.community

# ─── Database ──────────────────────────────────────────────────────────────

# Path to SQLite database file (default: bot/guild.db)
BOT_DB_PATH=

# ─── Consultation v2 (CV2) Integration ─────────────────────────────────────
# Optional: enables Guild ↔ CV2 proposal sync

# CV2 API base URL
CV2_API_URL=https://api.consultation.radix.network/v2

# CV2 API key (get from Radix Foundation)
CV2_API_KEY=

# CV2 webhook signature secret (set same value in CV2 dashboard)
CV2_WEBHOOK_SECRET=

# ─── CrumbsUp Integration ──────────────────────────────────────────────────
# Optional: enables Guild ↔ CrumbsUp DAO sync

# CrumbsUp API base URL
CRUMBSUP_API_URL=https://api.crumbsup.io

# CrumbsUp API key (get from CrumbsUp dashboard)
CRUMBSUP_API_KEY=

# CrumbsUp webhook signature secret (HMAC-SHA256)
CRUMBSUP_WEBHOOK_SECRET=

# Your DAO ID on CrumbsUp
CRUMBSUP_DAO_ID=guild-radix-dao

# Webhook endpoint path (must match your public URL)
CRUMBSUP_WEBHOOK_ENDPOINT=/api/webhooks/crumbsup

# ─── Discourse / RadixTalk ─────────────────────────────────────────────────
# Optional: post proposal results to RadixTalk forum

# RadixTalk API key
DISCOURSE_API_KEY=

# RadixTalk username for posting
DISCOURSE_API_USER=

# RadixTalk base URL
DISCOURSE_BASE_URL=https://radixtalk.com

# Category ID for governance posts
DISCOURSE_CATEGORY_ID=
