# ── LLM Provider ────────────────────────────────────────
# At least one provider key required
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model overrides (defaults shown)
ARCHITECT_MODEL=claude-sonnet-4-20250514
EXECUTOR_MODEL=claude-sonnet-4-20250514
REVIEWER_MODEL=claude-sonnet-4-20250514

# ── OmO State Manager ──────────────────────────────────
# Max tokens kept in agent context window (default: 32000)
MAX_CONTEXT_TOKENS=32000
# State file for persistent memory across sessions
STATE_FILE=.agent-state.json

# ── Clawhip Daemon ──────────────────────────────────────
# Discord bot token (optional — enables Discord routing)
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# GitHub webhook secret (optional — enables issue auto-triage)
GITHUB_WEBHOOK_SECRET=
GITHUB_REPO=bigdevxrd/radix-community-projects

# tmux session name to monitor (default: agent)
TMUX_SESSION=agent

# ── Project ─────────────────────────────────────────────
# Root of the project being worked on (default: cwd)
PROJECT_ROOT=.
# Plan output file
PLAN_FILE=plan.md
